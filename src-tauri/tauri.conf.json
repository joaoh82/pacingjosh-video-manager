{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Video Manager",
  "version": "1.0.0",
  "identifier": "com.pacingjosh.video-manager",
  "build": {
    "frontendDist": "../frontend/out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm --prefix ../frontend run dev",
    "beforeBuildCommand": "npm --prefix ../frontend run build"
  },
  "app": {
    "windows": [
      {
        "title": "Video Manager",
        "width": 1400,
        "height": 900,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "dmg", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [
      "binaries/ffmpeg",
      "binaries/ffprobe"
    ],
    "category": "Utility",
    "shortDescription": "Local-first video library manager",
    "longDescription": "Index, search, tag and browse large local video collections. Ships with FFmpeg bundled — no extra setup required."
  }
}
